# ──────────────────────────────────────────────────────────────
# DevBoard Nexus — Environment Variables Template
# Copy this file: cp .env.example backend/.env
# Then fill in your actual values below
# ──────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────────
PORT=5000

# URL of the frontend (used for CORS). Use * in development.
CLIENT_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Railway, Neon, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# ── Authentication ──────────────────────────────────────────────
# Use long, random strings in production (min 32 characters)
JWT_SECRET="your-super-secret-jwt-key-change-me"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-me"

# ── Google Gemini AI ────────────────────────────────────────────
# Get your key at: https://aistudio.google.com
# Keys always start with AIza...
GEMINI_API_KEY="AIza..."

# ── Rate Limiting (optional — shown defaults) ────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
